# nginx reverse proxy for dashboard.
#
# Place at /etc/nginx/sites-available/dashboard.conf, symlink into
# sites-enabled/, and `nginx -t && systemctl reload nginx`. Use certbot or
# acme.sh to provision the certificate paths referenced below.

server {
    listen 80;
    listen [::]:80;
    server_name apps.example.com;

    # Force TLS.
    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name apps.example.com;

    ssl_certificate     /etc/letsencrypt/live/apps.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/apps.example.com/privkey.pem;
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;

    # HSTS — once enabled, browsers will refuse plain HTTP for a year.
    add_header Strict-Transport-Security "max-age=31536000; includeSubDomains" always;

    # Slightly larger than the app's max_background_bytes default (10 MiB).
    client_max_body_size 12m;

    location / {
        proxy_pass         http://127.0.0.1:8080;

        # Reverse-proxy headers the app reads when its --trusted-proxies CIDR
        # list includes nginx's address (e.g., 127.0.0.1/32).
        proxy_set_header   Host              $host;
        proxy_set_header   X-Real-IP         $remote_addr;
        proxy_set_header   X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_set_header   X-Forwarded-Host  $host;

        proxy_http_version 1.1;
        proxy_set_header   Connection        "";

        # File uploads can take a moment; defaults are 60s which is fine
        # for the 10 MiB cap but bump if you raise that.
        proxy_read_timeout  60s;
        proxy_send_timeout  60s;

        # Lets-Encrypt-friendly: nginx handles the ACME challenge if you use
        # webroot mode, no extra config needed here.
    }

    # No /healthz exposure to the public side; if you want it, copy and uncomment:
    # location = /healthz {
    #     proxy_pass http://127.0.0.1:8080;
    #     access_log off;
    # }
}
